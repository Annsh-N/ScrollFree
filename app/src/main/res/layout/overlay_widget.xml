<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_shell_background"
    android:elevation="10dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingTop="7dp"
    android:paddingEnd="10dp"
    android:paddingBottom="7dp">

    <View
        android:id="@+id/statusDot"
        android:layout_width="9dp"
        android:layout_height="9dp"
        android:background="@drawable/overlay_dot_inactive" />

    <TextView
        android:id="@+id/blinkStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Inactive"
        android:textColor="#F3F7FF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/feedbackText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="@drawable/status_pill_background"
        android:paddingStart="8dp"
        android:paddingTop="3dp"
        android:paddingEnd="8dp"
        android:paddingBottom="3dp"
        android:text="Scroll ↓"
        android:textColor="#EAF1FF"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
